# Copie este arquivo para .env.local ou apenas crie no seu serviço de hospedagem (Ex: Vercel, Render)

# URL do seu Backend Node.js / Express acoplado ao PostgreSQL
# Exemplo local: http://192.168.0.x:3000/api
# Exemplo produção (Render): https://conecta-pontos-api.onrender.com/api
EXPO_PUBLIC_API_URL=https://sua-api.onrender.com/api

# A variável de ambiente que começa com EXPO_PUBLIC_ é visível diretamente 
# pelo App no client-side via process.env.EXPO_PUBLIC_API_URL.
